---
import { siteConfig, type Lang } from '../../data/site';
import { getLangFromUrl, getSafeAlternateUrl } from '../../lib/i18n';
import { getUI } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const navItems = siteConfig.nav[lang];
const altLang = lang === 'zh' ? 'en' : 'zh';
const altUrl = getSafeAlternateUrl(Astro.url);
const switchLabel = getUI(lang, 'lang.switch');
---

<header class="sticky top-0 z-50 backdrop-blur-sm bg-transparent">
  <div class="flex items-center justify-between h-16 px-6 sm:px-8 lg:px-12">
      <!-- Logo -->
      <a href={`/${lang}/`} class="logo-text text-2xl font-bold transition-colors inline-flex items-center gap-4">
        {siteConfig.name}
        <img src="/feather.png" alt="logo" class="w-12 h-12" />
      </a>

      <!-- Right side: Nav + Language toggle -->
      <div class="hidden md:flex items-center gap-4" style="transform: translateX(2px);">
        <nav class="flex items-center gap-1">
          {navItems.map((item) => {
            const isActive = Astro.url.pathname.replace(/\/$/, '') === item.href.replace(/\/$/, '');
            return (
              <a
                href={item.href}
                class:list={[
                  'px-3 py-2 text-base font-semibold rounded-md transition-colors',
                  isActive
                    ? 'text-accent font-bold'
                    : 'text-text-muted hover:text-text-secondary',
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
        <a
          href={altUrl}
          class="px-3 py-1.5 text-base text-text-muted hover:text-accent transition-colors"
        >
          {switchLabel}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2.5 rounded-md text-text-secondary hover:bg-bg-secondary"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300 ease-in-out px-6 sm:px-8 lg:px-12" style="max-height: 0; opacity: 0;">
      {navItems.map((item) => {
        const isActive = Astro.url.pathname.replace(/\/$/, '') === item.href.replace(/\/$/, '');
        return (
          <a
            href={item.href}
            class:list={[
              'block px-3 py-3 text-sm font-semibold rounded-md transition-colors',
              isActive
                ? 'text-accent font-bold'
                : 'text-text-muted hover:text-text-secondary',
            ]}
          >
            {item.label}
          </a>
        );
      })}
      <a
        href={altUrl}
        class="block px-3 py-3 text-sm text-text-muted hover:text-accent transition-colors"
      >
        {switchLabel}
      </a>
    </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerSVG = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>`;
  const closeSVG = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>`;
  let menuOpen = false;

  function closeMenu() {
    menuOpen = false;
    if (menu) { menu.style.maxHeight = '0'; menu.style.opacity = '0'; }
    document.body.style.overflow = '';
    if (btn) btn.innerHTML = hamburgerSVG;
  }

  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      if (menu) { menu.style.maxHeight = '300px'; menu.style.opacity = '1'; }
      document.body.style.overflow = 'hidden';
      if (btn) btn.innerHTML = closeSVG;
    } else {
      closeMenu();
    }
  });

  // Close menu when clicking nav links
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style is:global>
  .logo-text {
    font-family: 'Caveat', cursive;
    color: #8d6e63;
    font-size: 2rem;
  }

  .logo-text:hover {
    color: #a1887f;
  }
</style>
