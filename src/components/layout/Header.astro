---
import { siteConfig, type Lang } from '../../data/site';
import { getLangFromUrl, getSafeAlternateUrl } from '../../lib/i18n';
import { getUI } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const navItems = siteConfig.nav[lang];
const altLang = lang === 'zh' ? 'en' : 'zh';
const altUrl = getSafeAlternateUrl(Astro.url);
const switchLabel = getUI(lang, 'lang.switch');
---

<header class="sticky top-0 z-50 backdrop-blur-sm bg-transparent">
  <div class="flex items-center justify-between h-16 px-6 sm:px-8 lg:px-12">
      <!-- Logo -->
      <a href={`/${lang}/`} class="text-lg font-bold text-primary hover:text-primary-light transition-colors">
        {siteConfig.name}
      </a>

      <!-- Right side: Nav + Language toggle -->
      <div class="hidden md:flex items-center gap-4">
        <nav class="flex items-center gap-1">
          {navItems.map((item) => {
            const isActive = Astro.url.pathname.replace(/\/$/, '') === item.href.replace(/\/$/, '');
            return (
              <a
                href={item.href}
                class:list={[
                  'px-3 py-2 text-sm rounded-md transition-colors',
                  isActive
                    ? 'text-accent font-medium'
                    : 'text-text-muted hover:text-text-secondary',
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
        <a
          href={altUrl}
          class="px-3 py-1.5 text-sm rounded-md border border-border text-text-secondary hover:text-primary hover:border-primary transition-colors"
        >
          {switchLabel}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-text-secondary hover:bg-bg-secondary"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="md:hidden hidden pb-4 px-6 sm:px-8 lg:px-12">
      {navItems.map((item) => {
        const isActive = Astro.url.pathname.replace(/\/$/, '') === item.href.replace(/\/$/, '');
        return (
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 text-sm rounded-md transition-colors',
              isActive
                ? 'text-accent font-medium'
                : 'text-text-muted hover:text-text-secondary',
            ]}
          >
            {item.label}
          </a>
        );
      })}
      <a
        href={altUrl}
        class="block px-3 py-2 text-sm text-text-secondary hover:text-primary transition-colors"
      >
        {switchLabel}
      </a>
    </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
