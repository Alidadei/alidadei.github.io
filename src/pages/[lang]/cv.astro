---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang, siteConfig } from '../../data/site';
import AwardWall from '../../components/ui/AwardWall.tsx';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
---

<PageLayout title="CV">
  <h1 class="text-2xl md:text-3xl font-bold text-primary mb-8">CV / {lang === 'zh' ? '简历' : 'Resume'}</h1>

  <!-- Toolbar -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button
      id="btn-export"
      class="px-4 py-2 text-sm rounded-lg bg-primary text-white hover:opacity-90 transition-colors cursor-pointer"
    >
      📄 {lang === 'zh' ? '导出 PDF' : 'Export PDF'}
    </button>
    <button
      id="btn-toggle-all"
      class="px-4 py-2 text-sm rounded-lg border border-border text-text-secondary hover:bg-bg-tertiary transition-colors cursor-pointer"
    >
      {lang === 'zh' ? '全部收起' : 'Collapse all'}
    </button>
  </div>

  <div id="resume-content" class="space-y-4">
    <!-- Education -->
    <section data-section="education" class="border border-border rounded-lg overflow-hidden">
      <button class="cv-header w-full flex items-center justify-between p-4 hover:bg-bg-secondary transition-colors text-left cursor-pointer">
        <span class="font-bold text-lg text-primary">{lang === 'zh' ? '教育经历' : 'Education'}</span>
        <span class="cv-arrow text-text-muted transition-transform duration-300 rotate-180">▼</span>
      </button>
      <div class="cv-body overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height:2000px">
        <div class="px-4 pb-4 space-y-4">
          <div class="border-l-4 border-accent pl-4">
            <h3 class="font-bold text-lg text-primary">2025.09 - 2030.06</h3>
            <p>{lang === 'zh' ? '复旦大学 · 生物医学工程（人工智能方向）博士研究生' : 'Fudan University — Ph.D. in Biomedical Engineering (AI)'}</p>
          </div>
          <div class="border-l-4 border-accent pl-4">
            <h3 class="font-bold text-lg text-primary">2021.08 - 2025.07</h3>
            <p>{lang === 'zh' ? '中国海洋大学（985） · 电子信息工程 · 专业第4名保研' : 'Ocean University of China (985) — Electronic Information Engineering (Top 4, recommended for Ph.D.)'}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section data-section="skills" class="border border-border rounded-lg overflow-hidden">
      <button class="cv-header w-full flex items-center justify-between p-4 hover:bg-bg-secondary transition-colors text-left cursor-pointer">
        <span class="font-bold text-lg text-primary">{lang === 'zh' ? '专业技能' : 'Skills'}</span>
        <span class="cv-arrow text-text-muted transition-transform duration-300 rotate-180">▼</span>
      </button>
      <div class="cv-body overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height:2000px">
        <div class="px-4 pb-4 grid md:grid-cols-3 gap-6">
          <div class="p-4 rounded-lg bg-bg-secondary">
            <h3 class="font-semibold text-primary mb-3">{lang === 'zh' ? 'AI-Native 开发' : 'AI-Native Dev'}</h3>
            <div class="flex flex-wrap gap-2">
              {['AI Coding', 'CC/Codex', 'LangGraph', 'Agent', 'A2A'].map((s) => (
                <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
              ))}
            </div>
          </div>
          <div class="p-4 rounded-lg bg-bg-secondary">
            <h3 class="font-semibold text-primary mb-3">{lang === 'zh' ? '深度学习' : 'Deep Learning'}</h3>
            <div class="flex flex-wrap gap-2">
              {['PyTorch', 'TensorFlow', 'Python', 'LaTeX', 'Git'].map((s) => (
                <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
              ))}
            </div>
          </div>
          <div class="p-4 rounded-lg bg-bg-secondary">
            <h3 class="font-semibold text-primary mb-3">{lang === 'zh' ? '通用技能' : 'General'}</h3>
            <div class="flex flex-wrap gap-2">
              {['C/C++', 'MATLAB', 'CET-6: 622', 'CET-4: 657', lang === 'zh' ? '普通话二甲' : 'Putonghua 2A'].map((s) => (
                <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Internship -->
    <section data-section="internship" class="border border-border rounded-lg overflow-hidden">
      <button class="cv-header w-full flex items-center justify-between p-4 hover:bg-bg-secondary transition-colors text-left cursor-pointer">
        <span class="font-bold text-lg text-primary">{lang === 'zh' ? '实习经历' : 'Internship'}</span>
        <span class="cv-arrow text-text-muted transition-transform duration-300 rotate-180">▼</span>
      </button>
      <div class="cv-body overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height:2000px">
        <div class="px-4 pb-4 space-y-8">
          <div class="border-l-4 border-accent pl-4">
            <div class="flex items-baseline justify-between flex-wrap gap-2">
              <h3 class="font-bold text-lg text-primary">
                {lang === 'zh' ? '华为 · 多媒体智能协作实验室' : 'Huawei · Multimedia Intelligent Collaboration Lab'}
              </h3>
              <span class="text-sm text-text-muted">2026.01 - 2026.04</span>
            </div>
            <p class="text-text-secondary mt-2">
              {lang === 'zh'
                ? '参与 Multi-Agent 协作会议助手项目。基于 LangGraph 编排执行流，落地 A2A 协议实现跨 Agent 动态服务注册发现与解耦调用；实现语义路由优化与防误触发策略；搭建基于 LLM-as-a-Judge 的自动化评测流水线。'
                : 'Worked on a Multi-Agent collaborative meeting assistant. Built with LangGraph orchestration, implemented A2A protocol for cross-agent dynamic service discovery and decoupled invocation; optimized semantic routing to prevent false triggers; built LLM-as-a-Judge automated evaluation pipeline.'}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section data-section="projects" class="border border-border rounded-lg overflow-hidden">
      <button class="cv-header w-full flex items-center justify-between p-4 hover:bg-bg-secondary transition-colors text-left cursor-pointer">
        <span class="font-bold text-lg text-primary">{lang === 'zh' ? '项目经历' : 'Project Experience'}</span>
        <span class="cv-arrow text-text-muted transition-transform duration-300 rotate-180">▼</span>
      </button>
      <div class="cv-body overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height:2000px">
        <div class="px-4 pb-4 space-y-8">
          <div class="border-l-4 border-accent pl-4">
            <div class="flex items-baseline justify-between flex-wrap gap-2">
              <h3 class="font-bold text-lg text-primary">
                {lang === 'zh' ? '医疗大模型多模态信息融合与可解释性研究' : 'Medical LLM Multimodal Fusion & Interpretability Research'}
              </h3>
              <span class="text-sm text-text-muted">{lang === 'zh' ? '课题负责人' : 'Principal Investigator'}</span>
            </div>
            <p class="text-sm text-text-muted mb-2">2025.09 - {lang === 'zh' ? '至今' : 'Present'}</p>
            <p class="text-text-secondary">
              {lang === 'zh'
                ? '针对特殊罕见病用药疗效难以预测的现象，构建基于医疗大模型和多模态信息融合方法的可解释性算法架构。基于 Agent Workflow 进行医学数据清洗，使用预训练医学大模型提取各模态特征，构建中期融合架构实现跨模态信息互补。'
                : 'Building an interpretable algorithm architecture based on medical LLMs and multimodal fusion for predicting rare disease treatment efficacy. Using Agent Workflow for medical data preprocessing, pretrained medical LLMs for feature extraction, and mid-fusion architecture for cross-modal information complementarity.'}
            </p>
          </div>
          <div class="border-l-4 border-accent pl-4">
            <div class="flex items-baseline justify-between flex-wrap gap-2">
              <h3 class="font-bold text-lg text-primary">
                {lang === 'zh' ? '"智能自主系统"课题组' : '"Intelligent Autonomous Systems" Research Group'}
              </h3>
              <span class="text-sm text-text-muted">{lang === 'zh' ? '核心成员' : 'Core Member'}</span>
            </div>
            <p class="text-sm text-text-muted mb-2">2023.8 - 2024.8</p>
            <p class="text-text-secondary">
              {lang === 'zh'
                ? '参与"结合大语言模型和强化学习的机器人学习方法"文献调研，初步形成综述文章。同时参与"基于大语言模型的社交机器人Haru的自主行为学习方法"项目，完成ROS环境搭建和Gazebo仿真实验。'
                : 'Engaged in literature research on "Robot Learning Methods Combining LLMs and RL". Participated in the "Autonomous Behavioral Learning for Social Robot Haru" project, setting up ROS environment and conducting Gazebo simulations.'}
            </p>
          </div>
          <div class="border-l-4 border-accent pl-4">
            <div class="flex items-baseline justify-between flex-wrap gap-2">
              <h3 class="font-bold text-lg text-primary">
                {lang === 'zh' ? '校级大创：基于 STM32 的智能桌面系统' : 'Innovation Project: STM32 Intelligent Desktop System'}
              </h3>
              <span class="text-sm text-text-muted">{lang === 'zh' ? '负责人' : 'Project Leader'}</span>
            </div>
            <p class="text-sm text-text-muted mb-2">2022.11 - 2023.11</p>
            <p class="text-text-secondary">
              {lang === 'zh'
                ? '主持校级大创项目，设计多功能人机交互书桌系统。用Keil C编写控制框架，利用哈希思想和函数指针优化语音控制轮询过程。'
                : 'Led the project to design a multifunctional human-computer interaction desk system. Used Keil C for the control framework, optimizing voice control polling with hash thinking and function pointers.'}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section data-section="awards" class="border border-border rounded-lg overflow-hidden">
      <button class="cv-header w-full flex items-center justify-between p-4 hover:bg-bg-secondary transition-colors text-left cursor-pointer">
        <span class="font-bold text-lg text-primary">{lang === 'zh' ? '获奖荣誉' : 'Awards & Honors'}</span>
        <span class="cv-arrow text-text-muted transition-transform duration-300 rotate-180">▼</span>
      </button>
      <div class="cv-body overflow-hidden transition-[max-height] duration-300 ease-in-out" style="max-height:2000px">
        <div class="px-4 pb-4 space-y-3">
          {(lang === 'zh' ? [
            { title: '复旦大学相辉博士奖学金', desc: '复旦大学' },
            { title: '一等奖学金', desc: '中国海洋大学' },
            { title: '优秀学生称号', desc: '中国海洋大学' },
            { title: '华为HSD证书', desc: '' },
          ] : [
            { title: 'Fudan University Xianghui Doctoral Scholarship', desc: 'Fudan University' },
            { title: 'First-Class Scholarship', desc: 'Ocean University of China' },
            { title: 'Outstanding Student', desc: 'Ocean University of China' },
            { title: 'Huawei HSD Certificate', desc: '' },
          ]).map((award) => (
            <div class="flex items-center gap-3 p-3 rounded-lg border border-border">
              <span class="text-lg">🎖</span>
              <div>
                <p class="font-medium text-primary">{award.title}</p>
                {award.desc && <p class="text-sm text-text-muted">{award.desc}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- Contact (always visible, no accordion) -->
  <div class="mt-8">
    <h2 class="text-2xl font-bold text-primary mb-6 pb-2 border-b-2 border-primary">
      {lang === 'zh' ? '联系方式' : 'Contact'}
    </h2>
    <div class="space-y-3">
      <div class="flex items-center gap-3 p-4 rounded-lg border border-border">
        <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <div>
          <p class="text-sm text-text-muted">Email</p>
          <a href="mailto:13427917163@163.com" class="text-accent hover:text-accent-light">13427917163@163.com</a>
        </div>
      </div>
      <div class="flex items-center gap-3 p-4 rounded-lg border border-border">
        <svg class="w-5 h-5 text-accent shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <div>
          <p class="text-sm text-text-muted">GitHub</p>
          <a href={`https://github.com/${siteConfig.author.github}`} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-light">
            @{siteConfig.author.github}
          </a>
        </div>
      </div>
      <div class="flex items-center gap-3 p-4 rounded-lg border border-border">
        <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <div>
          <p class="text-sm text-text-muted">{lang === 'zh' ? '位置' : 'Location'}</p>
          <p class="text-text-secondary">{siteConfig.author.location}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Award wall easter egg at page bottom -->
  <AwardWall client:load lang={lang} />

  <!-- Vanilla JS accordion - no React dependency -->
  <script>
    const headers = document.querySelectorAll('.cv-header');
    const btnToggleAll = document.getElementById('btn-toggle-all');
    const btnExport = document.getElementById('btn-export');
    let allCollapsed = false;

    // Single section toggle
    headers.forEach(header => {
      header.addEventListener('click', () => {
        const body = header.nextElementSibling as HTMLElement;
        const arrow = header.querySelector('.cv-arrow') as HTMLElement;
        if (!body) return;

        const isOpen = body.style.maxHeight !== '0px';
        if (isOpen) {
          body.style.maxHeight = '0px';
          arrow?.classList.remove('rotate-180');
        } else {
          body.style.maxHeight = body.scrollHeight + 'px';
          arrow?.classList.add('rotate-180');
        }
      });
    });

    // Toggle all
    btnToggleAll?.addEventListener('click', () => {
      allCollapsed = !allCollapsed;
      headers.forEach(header => {
        const body = header.nextElementSibling as HTMLElement;
        const arrow = header.querySelector('.cv-arrow') as HTMLElement;
        if (!body) return;
        if (allCollapsed) {
          body.style.maxHeight = '0px';
          arrow?.classList.remove('rotate-180');
        } else {
          body.style.maxHeight = body.scrollHeight + 'px';
          arrow?.classList.add('rotate-180');
        }
      });
      btnToggleAll.textContent = allCollapsed
        ? (document.documentElement.lang?.startsWith('zh') ? '全部展开' : 'Expand all')
        : (document.documentElement.lang?.startsWith('zh') ? '全部收起' : 'Collapse all');
    });

    // Export PDF
    btnExport?.addEventListener('click', () => {
      headers.forEach(header => {
        const body = header.nextElementSibling as HTMLElement;
        const arrow = header.querySelector('.cv-arrow') as HTMLElement;
        if (body) body.style.maxHeight = body.scrollHeight + 'px';
        arrow?.classList.add('rotate-180');
      });
      setTimeout(() => window.print(), 200);
    });
  </script>
</PageLayout>
