---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang } from '../../data/site';
import InteractiveResume from '../../components/resume/InteractiveResume.tsx';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
---

<PageLayout title="CV">
  <h1 class="text-3xl font-bold text-primary mb-8">CV / {lang === 'zh' ? '简历' : 'Resume'}</h1>

  <InteractiveResume client:load lang={lang}>
    {/* Education section - rendered by Astro, consumed by the component */}
  </InteractiveResume>

  {/* Static fallback / print-friendly version */}
  <div id="resume-content" class="space-y-10 mt-8">
    <!-- Education -->
    <section data-section="education">
      <h2 class="text-2xl font-bold text-primary mb-6 pb-2 border-b-2 border-primary">
        {lang === 'zh' ? '教育经历' : 'Educational Experience'}
      </h2>
      <div class="space-y-4">
        <div class="border-l-4 border-accent pl-4">
          <h3 class="font-bold text-lg text-primary">2025.09 - 2030.06</h3>
          <p>{lang === 'zh' ? '复旦大学 · 生物医学工程（人工智能方向）博士研究生' : 'Fudan University — Ph.D. in Biomedical Engineering (AI)'}</p>
        </div>
        <div class="border-l-4 border-accent pl-4">
          <h3 class="font-bold text-lg text-primary">2021.08 - 2025.07</h3>
          <p>{lang === 'zh' ? '中国海洋大学（985） · 电子信息工程 · 专业第4名保研' : 'Ocean University of China (985) — Electronic Information Engineering (Top 4, recommended for Ph.D.)'}</p>
        </div>
        <div class="border-l-4 border-accent pl-4">
          <h3 class="font-bold text-lg text-primary">2018-2021</h3>
          <p>{lang === 'zh' ? '深圳外国语学校高中部' : 'Senior High School of Shenzhen Foreign Language School'}</p>
        </div>
        <div class="border-l-4 border-accent pl-4">
          <h3 class="font-bold text-lg text-primary">2015-2018</h3>
          <p>{lang === 'zh' ? '深圳外国语学校初中部' : 'Junior High School of Shenzhen Foreign Language School'}</p>
        </div>
      </div>
    </section>

    <!-- Research -->
    <section data-section="research">
      <h2 class="text-2xl font-bold text-primary mb-6 pb-2 border-b-2 border-primary">
        {lang === 'zh' ? '研究经历' : 'Research Experience'}
      </h2>
      <div class="space-y-8">
        <div class="border-l-4 border-accent pl-4">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <h3 class="font-bold text-lg text-primary">
              {lang === 'zh' ? '华为 · 多媒体智能协作实验室' : 'Huawei · Multimedia Intelligent Collaboration Lab'}
            </h3>
            <span class="text-sm text-text-muted">{lang === 'zh' ? '实习' : 'Internship'}</span>
          </div>
          <p class="text-sm text-text-muted mb-2">2026.01 - 2026.04</p>
          <p class="text-text-secondary">
            {lang === 'zh'
              ? '参与 Multi-Agent 协作会议助手项目。基于 LangGraph 编排执行流，落地 A2A 协议实现跨 Agent 动态服务注册发现与解耦调用；实现语义路由优化与防误触发策略；搭建基于 LLM-as-a-Judge 的自动化评测流水线。'
              : 'Worked on a Multi-Agent collaborative meeting assistant. Built with LangGraph orchestration, implemented A2A protocol for cross-agent dynamic service discovery and decoupled invocation; optimized semantic routing to prevent false triggers; built LLM-as-a-Judge automated evaluation pipeline.'}
          </p>
        </div>

        <div class="border-l-4 border-accent pl-4">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <h3 class="font-bold text-lg text-primary">
              {lang === 'zh' ? '医疗大模型多模态信息融合与可解释性研究' : 'Medical LLM Multimodal Fusion & Interpretability Research'}
            </h3>
            <span class="text-sm text-text-muted">{lang === 'zh' ? '课题负责人' : 'Principal Investigator'}</span>
          </div>
          <p class="text-sm text-text-muted mb-2">2025.09 - {lang === 'zh' ? '至今' : 'Present'}</p>
          <p class="text-text-secondary">
            {lang === 'zh'
              ? '针对特殊罕见病用药疗效难以预测的现象，构建基于医疗大模型和多模态信息融合方法的可解释性算法架构。基于 Agent Workflow 进行医学数据清洗，使用预训练医学大模型提取各模态特征，构建中期融合架构实现跨模态信息互补。'
              : 'Building an interpretable algorithm architecture based on medical LLMs and multimodal fusion for predicting rare disease treatment efficacy. Using Agent Workflow for medical data preprocessing, pretrained medical LLMs for feature extraction, and mid-fusion architecture for cross-modal information complementarity.'}
          </p>
        </div>

        <div class="border-l-4 border-accent pl-4">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <h3 class="font-bold text-lg text-primary">
              {lang === 'zh' ? '"智能自主系统"课题组' : '"Intelligent Autonomous Systems" Research Group'}
            </h3>
            <span class="text-sm text-text-muted">{lang === 'zh' ? '核心成员' : 'Core Member'}</span>
          </div>
          <p class="text-sm text-text-muted mb-2">2023.8 - 2024.8</p>
          <p class="text-text-secondary">
            {lang === 'zh'
              ? '参与"结合大语言模型和强化学习的机器人学习方法"文献调研，初步形成综述文章。同时参与"基于大语言模型的社交机器人Haru的自主行为学习方法"项目，完成ROS环境搭建和Gazebo仿真实验。'
              : 'Engaged in literature research on "Robot Learning Methods Combining LLMs and RL". Participated in the "Autonomous Behavioral Learning for Social Robot Haru" project, setting up ROS environment and conducting Gazebo simulations.'}
          </p>
        </div>

        <div class="border-l-4 border-accent pl-4">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <h3 class="font-bold text-lg text-primary">
              {lang === 'zh' ? '校级大创：基于 STM32 的智能桌面系统' : 'Innovation Project: STM32 Intelligent Desktop System'}
            </h3>
            <span class="text-sm text-text-muted">{lang === 'zh' ? '负责人' : 'Project Leader'}</span>
          </div>
          <p class="text-sm text-text-muted mb-2">2022.11 - 2023.11</p>
          <p class="text-text-secondary">
            {lang === 'zh'
              ? '主持校级大创项目，设计多功能人机交互书桌系统。用Keil C编写控制框架，利用哈希思想和函数指针优化语音控制轮询过程。'
              : 'Led the project to design a multifunctional human-computer interaction desk system. Used Keil C for the control framework, optimizing voice control polling with hash thinking and function pointers.'}
          </p>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section data-section="skills">
      <h2 class="text-2xl font-bold text-primary mb-6 pb-2 border-b-2 border-primary">
        {lang === 'zh' ? '技能' : 'Skills'}
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-4 rounded-lg bg-bg-secondary">
          <h3 class="font-semibold text-primary mb-3">{lang === 'zh' ? 'AI-Native 开发' : 'AI-Native Dev'}</h3>
          <div class="flex flex-wrap gap-2">
            {(lang === 'zh' ? ['AI Coding', 'CC/Codex', 'LangGraph', 'Agent', 'A2A'] : ['AI Coding', 'CC/Codex', 'LangGraph', 'Agent', 'A2A']).map((s) => (
              <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
            ))}
          </div>
        </div>
        <div class="p-4 rounded-lg bg-bg-secondary">
          <h3 class="font-semibold text-primary mb-3">{lang === 'zh' ? '深度学习' : 'Deep Learning'}</h3>
          <div class="flex flex-wrap gap-2">
            {['PyTorch', 'TensorFlow', 'Python', 'LaTeX', 'Git'].map((s) => (
              <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
            ))}
          </div>
        </div>
        <div class="p-4 rounded-lg bg-bg-secondary">
          <h3 class="font-semibold text-primary mb-3">{lang === 'zh' ? '通用技能' : 'General'}</h3>
          <div class="flex flex-wrap gap-2">
            {['C/C++', 'MATLAB', 'CET-6: 622', 'CET-4: 657', lang === 'zh' ? '普通话二甲' : 'Putonghua 2A'].map((s) => (
              <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section data-section="awards">
      <h2 class="text-2xl font-bold text-primary mb-6 pb-2 border-b-2 border-primary">
        {lang === 'zh' ? '获奖荣誉' : 'Awards & Honors'}
      </h2>
      <div class="space-y-3">
        {(lang === 'zh' ? [
          { title: '复旦大学相辉博士奖学金', desc: '复旦大学' },
          { title: '二等奖学金', desc: '中国海洋大学' },
          { title: '优秀学生称号', desc: '中国海洋大学' },
          { title: '全国英语阅读比赛一等奖', desc: '' },
          { title: '全国大学生商务英语竞赛二等奖', desc: '2023' },
          { title: '山东省机器人大赛三等奖', desc: '' },
          { title: '蓝桥杯电子赛省奖', desc: '第十四届' },
          { title: '华为HSD证书', desc: '' },
          { title: '美赛S奖', desc: 'MCM/ICM' },
        ] : [
          { title: 'Fudan University Xianghui Doctoral Scholarship', desc: 'Fudan University' },
          { title: 'Second-Class Scholarship', desc: 'Ocean University of China' },
          { title: 'Outstanding Student', desc: 'Ocean University of China' },
          { title: 'National English Reading Competition - First Prize', desc: '' },
          { title: 'Business English Competition - Second Prize', desc: '2023' },
          { title: 'Robot Competition - Third Prize (Shandong)', desc: '' },
          { title: 'Lanqiao Cup Electronic Competition - Provincial Award', desc: '14th' },
          { title: 'Huawei HSD Certificate', desc: '' },
          { title: 'MCM/ICM - S Award', desc: '' },
        ]).map((award) => (
          <div class="flex items-center gap-3 p-3 rounded-lg border border-border">
            <span class="text-lg">🎖</span>
            <div>
              <p class="font-medium text-primary">{award.title}</p>
              {award.desc && <p class="text-sm text-text-muted">{award.desc}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</PageLayout>
