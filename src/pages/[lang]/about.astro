---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang } from '../../data/site';
import { getUI } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = getUI.bind(null, lang as Lang);
---

<PageLayout title={lang === 'zh' ? '关于我' : 'About'}>
  <div class="space-y-8">
    <!-- Introduction -->
    <section class="prose prose-lg max-w-none">
      {lang === 'zh' ? (
        <>
          <p>我本科毕业于<strong>中国海洋大学（985）</strong>电子信息工程专业，专业排名第4名保研，现为<strong>复旦大学生物医学工程（人工智能方向）</strong>博士一年级研究生。</p>
          <p>我的<strong>研究兴趣</strong>包括大语言模型、多智能体系统、医疗 AI 和 AI-Native 开发范式。我持续跟踪 Agent 领域 SOTA 进展与范式演进，热衷于对前沿 Paper/开源项目进行深度探索与工程化落地。<strong>我期望在未来的科研生涯中为 AGI 的到来贡献自己的力量！</strong></p>
        </>
      ) : (
        <>
          <p>I graduated from <strong>Ocean University of China (985)</strong> with a B.Eng. in Electronic Information Engineering (ranked 4th in my major), and I am now a <strong>first-year Ph.D. student in Biomedical Engineering (AI direction) at Fudan University</strong>.</p>
          <p>My <strong>research interests</strong> include Large Language Models, Multi-Agent Systems, Medical AI, and AI-Native Development. I actively track SOTA advances in the Agent field and enjoy deep-diving into cutting-edge papers and open-source projects for engineering落地. <strong>I aspire to contribute to the arrival of AGI in my future research career!</strong></p>
        </>
      )}
    </section>

    <!-- Academic Background -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '学业成绩' : 'Academic Background'}</h2>
      <div class="space-y-3">
        <p><span class="underline">{lang === 'zh' ? '综合绩点' : 'Overall grade'}</span>: 93.97</p>
        <p><span class="underline">{lang === 'zh' ? '排名' : 'Ranking'}</span>: <strong>top 3.6%</strong> (4/113)</p>
      </div>
      <div class="text-center mt-4">
        <img src="/images/mygrade.png" alt="Grades" class="mx-auto rounded-lg shadow-sm" />
        <p class="text-sm text-text-muted mt-2">
          {lang === 'zh'
            ? '▲ 三年来学业成绩持续提升！不断进步，从不后退！'
            : '▲ Over the past three years, my academic performance has been continuously improving!'}
        </p>
      </div>
    </section>

    <!-- Honors -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '荣誉奖项' : 'Honors'}</h2>
      <p class="mb-4">{lang === 'zh' ? '复旦大学相辉博士奖学金、二等奖学金、优秀学生称号' : 'Fudan University Xianghui Doctoral Scholarship, Second-Class Scholarship, Outstanding Student'}</p>
      <div class="grid grid-cols-2 gap-4">
        <img src="/images/二等奖学金.jpg" alt="Scholarship" class="w-full rounded-lg shadow-sm" />
        <img src="/images/优秀学生.jpg" alt="Outstanding Student" class="w-full rounded-lg shadow-sm" />
      </div>
      <p class="text-sm text-text-muted text-center mt-2">{lang === 'zh' ? '获得的荣誉和奖项' : 'Honors and awards I\'ve got.'}</p>
    </section>

    <!-- English -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '英语能力' : 'English'}</h2>
      <p><strong>CET-4: 657; CET-6: 622</strong></p>
    </section>

    <!-- Competitions -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '竞赛经历' : 'Competitions'}</h2>
      <p class="mb-4">
        {lang === 'zh'
          ? '我参加了大量竞赛，全面提升了专业技能和团队协作能力：'
          : 'I have also participated in numerous competitions, which have comprehensively improved my professional and collaborative skills:'}
      </p>
      <div class="grid grid-cols-2 gap-4">
        <img src="/images/第四届国际海洋工程准备科技创新大赛.jpg" alt="Competition 1" class="w-full rounded-lg shadow-sm" />
        <img src="/images/第五届海工.jpg" alt="Competition 2" class="w-full rounded-lg shadow-sm" />
        <img src="/images/山东省机器人大赛三等奖.jpg" alt="Competition 3" class="w-full rounded-lg shadow-sm" />
        <img src="/images/第十四届蓝桥杯电子赛省奖.jpg" alt="Competition 4" class="w-full rounded-lg shadow-sm" />
      </div>
      <p class="text-center text-text-muted mt-2">{lang === 'zh' ? '等等……' : 'and so on ......'}</p>
    </section>

    <!-- Social Practice -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '社会实践' : 'Social Practice'}</h2>
      <p class="mb-4">
        {lang === 'zh'
          ? '此外，我参与了许多社会实践活动，大大提升了时间管理和组织能力。'
          : 'Besides, I\'ve taken part in many social practice activities. These activities have significantly strengthened my time management and organizational capabilities.'}
      </p>
      <div class="text-center">
        <img src="/images/华为HSD证书.jpg" alt="Huawei HSD Certificate" class="mx-auto max-w-xs rounded-lg shadow-sm" />
      </div>
    </section>

    <!-- Other -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '其他' : 'Other Aspects'}</h2>
      <p class="mb-2">
        {lang === 'zh'
          ? '学业之外，我有多种爱好，如慢跑与乒乓球、拉小提琴和练习书法，它们是我学习生活的调味品。'
          : 'Outside of academics, I have a variety of hobbies, such as jogging & table tennis, playing the violin and practicing calligraphy, they are the spices of my study life.'}
      </p>
      <p>
        {lang === 'zh'
          ? '技术方面，我熟练使用 AI-Native 开发范式（CC/Codex 重度使用），掌握 PyTorch、TensorFlow 等深度学习框架，具备扎实的论文调研、算法复现与创新点设计能力。'
          : 'In terms of technical skills, I am proficient in AI-Native development (heavy user of CC/Codex), skilled in PyTorch, TensorFlow and other deep learning frameworks, with solid capabilities in paper research, algorithm reproduction and innovation design.'}
      </p>
    </section>

    <!-- News -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">News</h2>
      <div class="border-t border-border pt-4 space-y-2">
        <p><span class="text-red-700 font-bold">news!</span> 2026.01 - 2026.04. {lang === 'zh'
          ? '完成**华为多媒体智能协作实验室**实习，参与多 Agent 会议助手项目开发。'
          : 'Completed internship at **Huawei Multimedia Intelligent Collaboration Lab**, working on a Multi-Agent meeting assistant project.'}</p>
        <p><span class="text-red-700 font-bold">news!</span> 2025.09. {lang === 'zh'
          ? '正式入学**复旦大学生物医学工程（人工智能方向）博士项目**！'
          : 'Officially enrolled in the **Ph.D. program in Biomedical Engineering (AI) at Fudan University**!'}</p>
        <p><span class="text-red-700 font-bold">news!</span> 26/09/2024. {lang === 'zh'
          ? '我已被**复旦大学生物医学工程博士项目直博录取**！'
          : 'I have been **directly admitted to the Ph.D. of Biomedical Engineering at Fudan University**!'}</p>
      </div>
    </section>

    <!-- Contact -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">{lang === 'zh' ? '联系我' : 'Contact'}</h2>
      <div class="space-y-2">
        <p>{lang === 'zh' ? '邮箱' : 'Email'}: yuhl@stu.ouc.edu.cn / 13427917163@163.com</p>
        <p>{lang === 'zh' ? '微信' : 'WeChat'}: yhl2765428788</p>
        <img src="/images/个人微信.png" alt="WeChat QR" class="max-w-xs rounded-lg" />
      </div>
    </section>
  </div>
</PageLayout>
