---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang, siteConfig } from '../../data/site';
import { getCollection, render } from 'astro:content';
import AwardWall from '../../components/ui/AwardWall.tsx';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };

// 内容来自 src/content/about/{zh,en}.md —— 只改 .md 即可更新页面
const entries = await getCollection('about', ({ data }) => data.lang === lang);
const entry = entries[0];
const { Content } = await render(entry);
const d = entry.data;
---

<PageLayout title={lang === 'zh' ? '关于我' : 'About Me'}>
  <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

    <!-- 📱 手机端:小提琴 + 联系方式 小卡片(桌面隐藏) -->
    <div class="lg:hidden flex items-center gap-4 p-4 rounded-xl bg-bg-secondary border border-border">
      <img src="/images/violin.jpg" alt="avatar" class="w-14 h-14 rounded-full shrink-0 object-cover" />
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm text-text-secondary min-w-0">
        <a href={`mailto:${siteConfig.author.email}`} class="flex items-center gap-1.5 hover:text-accent min-w-0">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="truncate">{siteConfig.author.email}</span>
        </a>
        <a href={`https://github.com/${siteConfig.author.github}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:text-accent">
          <svg class="w-4 h-4 text-accent shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>@{siteConfig.author.github}</span>
        </a>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>{siteConfig.author.location}</span>
        </span>
      </div>
    </div>

    <!-- ═══ 左栏:头像 + 联系方式(桌面端 sticky,手机隐藏) ═══ -->
    <aside class="hidden lg:block w-60 lg:shrink-0">
      <div class="lg:sticky lg:top-24 space-y-5">
        <img src="/images/violin.jpg" alt="avatar" class="w-28 h-28 lg:w-32 lg:h-32 rounded-full mx-auto lg:mx-0 ring-4 ring-bg-secondary shadow-sm object-cover" />
        <div class="text-center lg:text-left">
          <p class="font-bold text-lg text-primary">{siteConfig.author.name}</p>
          <p class="text-sm text-text-muted leading-snug mt-0.5">{siteConfig.author.bio[lang]}</p>
        </div>

        <div class="pt-3 border-t border-border">
          <h2 class="text-xs font-semibold text-text-muted uppercase tracking-widest mb-3">
            {lang === 'zh' ? '联系方式' : 'Contact'}
          </h2>
          <ul class="space-y-2.5 text-sm">
            <li>
              <a href={`mailto:${siteConfig.author.email}`} class="flex items-center gap-2.5 text-text-secondary hover:text-accent transition-colors">
                <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="truncate">{siteConfig.author.email}</span>
              </a>
            </li>
            <li>
              <a href={`https://github.com/${siteConfig.author.github}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-text-secondary hover:text-accent transition-colors">
                <svg class="w-4 h-4 text-accent shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                <span>@{siteConfig.author.github}</span>
              </a>
            </li>
            <li class="flex items-center gap-2.5 text-text-secondary">
              <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{siteConfig.author.location}</span>
            </li>
          </ul>
        </div>
      </div>
    </aside>

    <!-- ═══ 右栏:主要内容 ═══ -->
    <div class="flex-1 min-w-0 max-w-3xl">
      <h1 class="text-2xl md:text-3xl font-bold text-primary mb-10">
        {lang === 'zh' ? '关于我' : 'About Me'}
      </h1>

      <!-- 自我介绍:渲染 Markdown 正文,复用 .prose 排版样式 -->
      <section class="mb-12 prose max-w-none text-lg sm:text-xl">
        <Content />
      </section>

      <!-- News -->
      {d.news.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-6 pb-2 border-b border-border">
            {lang === 'zh' ? '近期动态' : 'News'}
          </h2>
          <div class="space-y-3">
            {d.news.map((item) => (
              <div class="flex gap-3 sm:gap-4 items-baseline py-2 flex-wrap">
                <span class="shrink-0 text-sm text-text-muted font-mono w-36 sm:w-44 whitespace-nowrap text-left">{item.date}</span>
                <span class="text-text-secondary">{item.text}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Education -->
      {d.education.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-6 pb-2 border-b border-border">
            {lang === 'zh' ? '教育经历' : 'Education'}
          </h2>
          <div class="space-y-6">
            {d.education.map((e) => (
              <div class="border-l-4 border-accent pl-5">
                <div class="flex items-baseline justify-between flex-wrap gap-2">
                  <h3 class="font-bold text-lg text-primary">{e.school}</h3>
                  <span class="text-sm text-text-muted whitespace-nowrap">{e.period}</span>
                </div>
                <p class="text-text-secondary mt-1">{e.degree}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Internship -->
      {d.internship.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-6 pb-2 border-b border-border">
            {lang === 'zh' ? '实习经历' : 'Internship'}
          </h2>
          <div class="space-y-6">
            {d.internship.map((i) => (
              <div class="border-l-4 border-accent pl-5">
                <div class="flex items-baseline justify-between flex-wrap gap-2">
                  <h3 class="font-bold text-lg text-primary">{i.company}</h3>
                  <span class="text-sm text-text-muted whitespace-nowrap">{i.period}</span>
                </div>
                <p class="text-text-secondary mt-2">{i.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Research / Projects -->
      {d.research.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-6 pb-2 border-b border-border">
            {lang === 'zh' ? '研究 & 项目' : 'Research & Projects'}
          </h2>
          <div class="space-y-8">
            {d.research.map((r) => (
              <div class="border-l-4 border-accent pl-5">
                <div class="flex items-baseline justify-between flex-wrap gap-2">
                  <h3 class="font-bold text-lg text-primary">{r.title}</h3>
                  {r.role && <span class="text-sm text-text-muted whitespace-nowrap">{r.role}</span>}
                </div>
                {r.period && <p class="text-sm text-text-muted mb-2">{r.period}</p>}
                <p class="text-text-secondary">{r.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Awards -->
      {d.awards.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-6 pb-2 border-b border-border">
            {lang === 'zh' ? '获奖荣誉' : 'Awards & Honors'}
          </h2>
          <div class="space-y-3">
            {d.awards.map((award) => (
              <div class="flex items-center gap-3 p-3 rounded-lg border border-border">
                <span class="text-lg">🎖</span>
                <div>
                  <p class="font-medium text-primary">{award.title}</p>
                  {award.desc && <p class="text-sm text-text-muted">{award.desc}</p>}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Skills -->
      {d.skills.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl md:text-2xl font-bold text-primary mb-6 pb-2 border-b border-border">
            {lang === 'zh' ? '专业技能' : 'Skills'}
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {d.skills.map((group) => (
              <div class="p-4 rounded-lg bg-bg-secondary">
                <h3 class="font-semibold text-primary mb-3">{group.name}</h3>
                <div class="flex flex-wrap gap-2">
                  {group.items.map((s) => (
                    <span class="px-2 py-1 text-sm rounded bg-bg-tertiary text-text-secondary">{s}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Award wall easter egg -->
      <AwardWall client:load lang={lang} />
    </div>

  </div>
</PageLayout>
