---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang } from '../../data/site';
import { getCollection, render } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };

const allProjects = await getCollection('projects', ({ data }) => data.lang === lang);
const projects = allProjects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get portfolio items too
const portfolioItems = await getCollection('portfolio');
---

<PageLayout title={lang === 'zh' ? '项目' : 'Projects'}>
  <h1 class="text-2xl md:text-3xl font-bold text-primary mb-8">{lang === 'zh' ? '项目' : 'Projects'}</h1>

  {/* Portfolio items from Jekyll */}
  {portfolioItems.length > 0 && (
    <div class="space-y-6 mb-12">
      {portfolioItems.map((item) => {
        const Tag = item.data.link ? 'a' : 'div';
        const linkProps = item.data.link
          ? { href: item.data.link, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag {...linkProps} class="block p-6 rounded-lg border border-border hover:border-accent/50 transition-all">
            <h2 class="text-xl font-semibold text-primary mb-2">{item.data.title}</h2>
            {item.data.excerpt && (
              <p class="text-text-secondary text-sm mb-4">{item.data.excerpt}</p>
            )}
            {item.data.image && (
              <img src={item.data.image} alt={item.data.title} class="w-full rounded-lg mb-4" />
            )}
            {item.data.link && (
              <span class="text-sm text-accent hover:text-accent-light">
                {lang === 'zh' ? '查看详情' : 'View Details'} &rarr;
              </span>
            )}
          </Tag>
        );
      })}
    </div>
  )}

  {/* New projects collection */}
  {projects.length === 0 ? (
    <p class="text-text-muted">{lang === 'zh' ? '暂无项目' : 'No projects yet.'}</p>
  ) : (
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div class="p-6 rounded-lg border border-border hover:border-accent/50 hover:shadow-sm transition-all">
          {project.data.image && (
            <img src={project.data.image} alt={project.data.title} class="w-full h-40 object-cover rounded-lg mb-4" />
          )}
          <h2 class="text-lg font-semibold text-primary mb-2">{project.data.title}</h2>
          <p class="text-text-muted text-sm mb-4">{project.data.description}</p>
          {project.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1 mb-3">
              {project.data.tags.map((tag) => (
                <span class="px-2 py-0.5 text-xs rounded bg-bg-tertiary text-text-muted">{tag}</span>
              ))}
            </div>
          )}
          <div class="flex gap-3">
            {project.data.github && (
              <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent-light">
                GitHub &rarr;
              </a>
            )}
            {project.data.demo && (
              <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent-light">
                {lang === 'zh' ? '在线演示' : 'Live Demo'} &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</PageLayout>
