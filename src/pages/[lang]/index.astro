---
import PageLayout from '../../layouts/PageLayout.astro';
import { siteConfig, type Lang } from '../../data/site';
import { getCollection } from 'astro:content';
import SunArc from '../../components/ui/SunArc.tsx';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };

// Get the latest post
const allPosts = await getCollection('posts', ({ data }) => data.lang === lang && !data.draft);
const latestPost = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

<PageLayout title={lang === 'zh' ? '首页' : 'Home'}>
  <!-- Make body transparent so 3D background shows through -->
  <style is:global>
    body { background: transparent !important; }
    @media (max-width: 767px) {
      body { background: var(--color-bg) !important; }
    }
  </style>

  <!-- 3D Background — desktop only, fullscreen fixed -->
  <div id="bg-container" class="fixed inset-0 w-full h-full" style="z-index: 0;">
    <!-- Static fallback for mobile -->
    <div id="bg-static" class="md:hidden w-full h-full bg-gradient-to-b from-[#f5e6d3] via-[#e8c8d8] to-[#b8d0f0]"></div>
    <!-- 3D iframe for desktop -->
    <iframe
      id="bg-3d"
      src="/3d-background.html"
      class="hidden md:block fixed inset-0 w-full h-full border-0"
      title="3D Background"
    ></iframe>
  </div>

  <!-- All page content above the 3D scene -->
  <div class="relative pointer-events-none" style="z-index: 1;">
    <!-- Layer 1: Sun Arc Animation -->
    <SunArc client:idle lang={lang} />

    <!-- Layer 2: Spacer — smaller on mobile -->
    <div class="h-32 md:h-72"></div>

    <!-- Layer 3: Recent Post -->
    {latestPost && (
      <section class="pt-8 md:pt-12 pb-20 md:pb-32 max-w-2xl mx-auto px-4 pointer-events-auto">
        <div class="flex items-center justify-between mb-6 md:mb-8">
          <h2 class="text-lg md:text-xl font-bold" style="color: rgba(220,225,230,0.9);">
            {lang === 'zh' ? '最新文章' : 'Recent Post'}
          </h2>
          <a href={`/${lang}/blog/`} class="text-sm transition-colors" style="color: rgba(200,208,216,0.7);">
            {lang === 'zh' ? '所有文章 →' : 'All posts →'}
          </a>
        </div>
        <a
          href={`/${lang}/blog/${latestPost.id.split('/').slice(1).join('/')}/`}
          class="block group"
        >
          <div class="flex items-baseline gap-3 md:gap-4">
            <time class="shrink-0 text-xs md:text-sm font-mono" style="color: rgba(180,190,200,0.6);">
              {latestPost.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                year: 'numeric', month: 'short', day: 'numeric'
              })}
            </time>
            <h3 class="text-base md:text-lg font-semibold group-hover:text-accent transition-colors" style="color: rgba(220,225,230,0.9);">
              {latestPost.data.title}
            </h3>
          </div>
          {latestPost.data.description && (
            <p class="text-sm mt-2 ml-0 md:ml-[calc(8rem+1rem)]" style="color: rgba(180,190,200,0.5);">
              {latestPost.data.description}
            </p>
          )}
        </a>
      </section>
    )}
  </div>
</PageLayout>
