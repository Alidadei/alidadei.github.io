---
import PageLayout from '../../layouts/PageLayout.astro';
import { siteConfig, type Lang } from '../../data/site';
import { getCollection } from 'astro:content';
import SunArc from '../../components/ui/SunArc.tsx';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };

// Get the latest post
const allPosts = await getCollection('posts', ({ data }) => data.lang === lang && !data.draft);
const latestPost = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

// 光年进度基数(2D 阶段「星际航行」叙事;与末尾 <script> 内 TRAVEL_BASE 保持一致)
const TRAVEL_BASE = 888;
---

<PageLayout title={lang === 'zh' ? '首页' : 'Home'} homeBg={true}>
  <style is:global>
    body { background: transparent !important; }
    .hero-btn { color: rgba(235,238,242,0.92); transition: color 0.3s ease; }
    .hero-btn:hover { color: rgba(255,240,200,0.95); }
  </style>

  <script>
    // ── Animated 2D Starry Sky Background ──
    // Static elements (gradient, milky way, nebulae, dust, vignette) cached on offscreen canvas.
    // Animated elements (twinkling stars, sliding shooting stars) redrawn each frame.
    (function() {
      const c = document.getElementById('bg-2d');
      if (!c) return;
      const ctx = c.getContext('2d');
      // 手机端:降低 DPR 上限 + 减少 warp 星数,减轻 canvas 绘制负担
      const isMobileDevice = Math.min(window.innerWidth, window.innerHeight) < 768;
      const dpr = Math.min(devicePixelRatio, isMobileDevice ? 1.5 : 2);
      const warpCount = isMobileDevice ? 80 : 150;
      let W, H, animId;

      let seed = 42;
      function srand(s) { seed = s; }
      function rand() { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; }

      const starColors = [[255,240,200],[200,220,255],[255,200,150],[180,200,255],[255,255,230]];
      const medColors = ['200,215,255','255,245,220','180,200,255','255,220,180'];

      let staticCanvas = null;
      let twinkleStars = [];
      let warpStars = [];
      let shooters = [];
      let shootTimer = 1 + Math.random() * 2;
      let lastTime = 0;

      function init() {
        W = window.innerWidth; H = window.innerHeight;
        c.width = W * dpr; c.height = H * dpr;
        twinkleStars = [];
        srand(42);

        // ── Static offscreen canvas ──
        staticCanvas = document.createElement('canvas');
        staticCanvas.width = W * dpr; staticCanvas.height = H * dpr;
        const sctx = staticCanvas.getContext('2d');
        sctx.scale(dpr, dpr);

        // Deep space background
        const grad = sctx.createRadialGradient(W*0.5, H*0.4, 0, W*0.5, H*0.4, Math.max(W,H)*0.8);
        grad.addColorStop(0,   '#080c20');
        grad.addColorStop(0.3, '#060a18');
        grad.addColorStop(0.6, '#040812');
        grad.addColorStop(1,   '#020408');
        sctx.fillStyle = grad;
        sctx.fillRect(0, 0, W, H);

        // Milky Way
        sctx.save();
        sctx.translate(W * 0.45, H * 0.3);
        sctx.rotate(-0.55);
        for (let layer = 0; layer < 3; layer++) {
          const mwGrad = sctx.createRadialGradient(0, 0, 0, 0, 0, W * (0.3 + layer * 0.1));
          const intensity = 0.07 - layer * 0.015;
          mwGrad.addColorStop(0, `rgba(${140+layer*20},${150+layer*15},${200-layer*20},${intensity})`);
          mwGrad.addColorStop(0.4, `rgba(${100+layer*15},${120+layer*10},${180-layer*15},${intensity * 0.5})`);
          mwGrad.addColorStop(1, 'rgba(0,0,0,0)');
          sctx.fillStyle = mwGrad;
          sctx.fillRect(-W * 0.55, -H * (0.04 + layer * 0.02), W * 1.1, H * (0.08 + layer * 0.04));
        }
        sctx.restore();

        // Nebulae
        const nebulae = [
          { x: 0.15, y: 0.2,  rx: 0.22, ry: 0.12, color: [100, 60, 160], a: 0.06 },
          { x: 0.8,  y: 0.12, rx: 0.16, ry: 0.10, color: [60, 100, 180], a: 0.05 },
          { x: 0.5,  y: 0.55, rx: 0.18, ry: 0.14, color: [160, 80, 100], a: 0.04 },
          { x: 0.35, y: 0.7,  rx: 0.14, ry: 0.08, color: [80, 140, 160], a: 0.04 },
          { x: 0.7,  y: 0.45, rx: 0.20, ry: 0.10, color: [120, 80, 180], a: 0.05 },
          { x: 0.25, y: 0.5,  rx: 0.10, ry: 0.14, color: [180, 100, 80], a: 0.03 },
        ];
        for (const n of nebulae) {
          sctx.save();
          sctx.translate(W * n.x, H * n.y);
          sctx.scale(1, n.ry / n.rx);
          const ng = sctx.createRadialGradient(0, 0, 0, 0, 0, Math.min(W, H) * n.rx);
          ng.addColorStop(0, `rgba(${n.color[0]},${n.color[1]},${n.color[2]},${n.a})`);
          ng.addColorStop(0.5, `rgba(${n.color[0]},${n.color[1]},${n.color[2]},${n.a * 0.4})`);
          ng.addColorStop(1, 'rgba(0,0,0,0)');
          sctx.fillStyle = ng;
          sctx.beginPath(); sctx.arc(0, 0, Math.min(W, H) * n.rx, 0, Math.PI * 2); sctx.fill();
          sctx.restore();
        }

        // Dust stars (400) — static, too faint to need twinkle
        for (let i = 0; i < 400; i++) {
          const x = rand() * W, y = rand() * H;
          sctx.fillStyle = `rgba(180,190,220,${0.1 + rand() * 0.25})`;
          sctx.fillRect(x, y, 0.2 + rand() * 0.5, 0.2 + rand() * 0.5);
        }
        // Small stars (150) — static
        for (let i = 0; i < 150; i++) {
          const x = rand() * W, y = rand() * H;
          sctx.fillStyle = `rgba(200,210,240,${0.2 + rand() * 0.4})`;
          sctx.beginPath(); sctx.arc(x, y, 0.5 + rand(), 0, Math.PI * 2); sctx.fill();
        }

        // Galaxy clusters
        const galaxies = [
          { x: 0.12, y: 0.35, r: 0.025, a: 0.08 },
          { x: 0.88, y: 0.55, r: 0.02, a: 0.06 },
          { x: 0.6, y: 0.75, r: 0.018, a: 0.05 },
          { x: 0.3, y: 0.15, r: 0.015, a: 0.06 },
          { x: 0.75, y: 0.28, r: 0.022, a: 0.07 },
        ];
        for (const g of galaxies) {
          const gg = sctx.createRadialGradient(W*g.x, H*g.y, 0, W*g.x, H*g.y, Math.min(W,H)*g.r);
          gg.addColorStop(0, `rgba(200,180,220,${g.a})`);
          gg.addColorStop(0.5, `rgba(160,150,200,${g.a * 0.3})`);
          gg.addColorStop(1, 'rgba(0,0,0,0)');
          sctx.fillStyle = gg;
          sctx.beginPath(); sctx.arc(W*g.x, H*g.y, Math.min(W,H)*g.r, 0, Math.PI*2); sctx.fill();
        }

        // Vignette
        const vGrad = sctx.createRadialGradient(W/2, H/2, Math.min(W,H)*0.25, W/2, H/2, Math.max(W,H)*0.75);
        vGrad.addColorStop(0, 'rgba(0,0,0,0)');
        vGrad.addColorStop(1, 'rgba(0,0,0,0.4)');
        sctx.fillStyle = vGrad;
        sctx.fillRect(0, 0, W, H);

        // ── Prepare twinkle star data (layers 3-5) ──
        // Layer 3: Medium (60)
        for (let i = 0; i < 60; i++) {
          twinkleStars.push({
            x: rand()*W, y: rand()*H,
            size: 1 + rand()*1.2, baseAlpha: 0.4 + rand()*0.4,
            speed: 0.8 + rand()*2, phase: rand()*Math.PI*2,
            col: medColors[Math.floor(rand()*medColors.length)],
          });
        }
        // Layer 4: Bright with glow (25)
        for (let i = 0; i < 25; i++) {
          const raw = starColors[Math.floor(rand()*starColors.length)];
          twinkleStars.push({
            x: rand()*W, y: rand()*H,
            size: 1.2 + rand()*2, baseAlpha: 0.9,
            speed: 0.4 + rand()*1.2, phase: rand()*Math.PI*2,
            col: `${raw[0]},${raw[1]},${raw[2]}`, glow: true,
          });
        }
        // Layer 5: Prominent with spikes (8)
        for (let i = 0; i < 8; i++) {
          const raw = starColors[Math.floor(rand()*starColors.length)];
          twinkleStars.push({
            x: W*0.08 + rand()*W*0.84, y: H*0.05 + rand()*H*0.7,
            size: 2 + rand()*2.5, baseAlpha: 0.95,
            speed: 0.2 + rand()*0.6, phase: rand()*Math.PI*2,
            col: `${raw[0]},${raw[1]},${raw[2]}`, spikes: true,
          });
        }

        // ── Warp stars (向前飞行视角:星点从中心向外辐射) ──
        warpStars = [];
        for (let i = 0; i < warpCount; i++) {
          warpStars.push({ x: (rand()-0.5)*2, y: (rand()-0.5)*2, z: rand(), pz: 0 });
        }
      }

      function spawnShooter() {
        const angle = 0.3 + Math.random() * 0.5;
        const speed = 280 + Math.random() * 220;
        return {
          x: Math.random() * W * 0.7 + W * 0.1,
          y: Math.random() * H * 0.35,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: 1, decay: 0.5 + Math.random() * 0.3,
          len: 40 + Math.random() * 60,
        };
      }

      function animate(time) {
        const dt = Math.min((time - lastTime) / 1000, 0.1);
        lastTime = time;
        const t = time / 1000;

        // Blit cached static background
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.drawImage(staticCanvas, 0, 0);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        // ── Twinkle stars ──
        for (const s of twinkleStars) {
          const flicker = 0.5 + 0.5 * Math.sin(t * s.speed + s.phase);
          const alpha = s.baseAlpha * (0.3 + 0.7 * flicker);

          if (s.spikes) {
            // Glow
            const glow = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.size * 8);
            glow.addColorStop(0, `rgba(${s.col},${0.2 * flicker})`);
            glow.addColorStop(0.2, `rgba(${s.col},${0.06 * flicker})`);
            glow.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = glow;
            ctx.fillRect(s.x - s.size*8, s.y - s.size*8, s.size*16, s.size*16);
            // Core
            ctx.fillStyle = `rgba(${s.col},${alpha})`;
            ctx.beginPath(); ctx.arc(s.x, s.y, s.size, 0, Math.PI*2); ctx.fill();
            // Cross spikes
            const spikeA = 0.35 * flicker;
            ctx.strokeStyle = `rgba(${s.col},${spikeA})`;
            ctx.lineWidth = 0.8;
            const sLen = s.size * 6;
            ctx.beginPath();
            ctx.moveTo(s.x - sLen, s.y); ctx.lineTo(s.x + sLen, s.y);
            ctx.moveTo(s.x, s.y - sLen); ctx.lineTo(s.x, s.y + sLen);
            ctx.stroke();
            // Diagonal spikes
            ctx.strokeStyle = `rgba(${s.col},${spikeA * 0.4})`;
            const dS = sLen * 0.5;
            ctx.beginPath();
            ctx.moveTo(s.x - dS, s.y - dS); ctx.lineTo(s.x + dS, s.y + dS);
            ctx.moveTo(s.x + dS, s.y - dS); ctx.lineTo(s.x - dS, s.y + dS);
            ctx.stroke();
          } else if (s.glow) {
            const glow = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.size * 5);
            glow.addColorStop(0, `rgba(${s.col},${0.25 * flicker})`);
            glow.addColorStop(0.3, `rgba(${s.col},${0.06 * flicker})`);
            glow.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = glow;
            ctx.fillRect(s.x - s.size*5, s.y - s.size*5, s.size*10, s.size*10);
            ctx.fillStyle = `rgba(${s.col},${alpha})`;
            ctx.beginPath(); ctx.arc(s.x, s.y, s.size, 0, Math.PI*2); ctx.fill();
          } else {
            ctx.fillStyle = `rgba(${s.col},${alpha})`;
            ctx.beginPath(); ctx.arc(s.x, s.y, s.size, 0, Math.PI*2); ctx.fill();
          }
        }

        // ── Warp stars (向前飞行视角:星点从中心向外辐射 + 拖尾) ──
        const cx = W/2, cy = H/2, spread = 0.55, warpSpeed = 0.3;
        for (const s of warpStars) {
          s.pz = s.z;
          s.z -= warpSpeed * dt;
          if (s.z < 0.02) {
            s.z = 1; s.pz = 1;
            s.x = (rand()-0.5)*2; s.y = (rand()-0.5)*2;
          }
          const sx = cx + (s.x / s.z) * cx * spread;
          const sy = cy + (s.y / s.z) * cy * spread;
          const psx = cx + (s.x / s.pz) * cx * spread;
          const psy = cy + (s.y / s.pz) * cy * spread;
          const r = 1 - s.z;
          ctx.strokeStyle = `rgba(200,220,255,${Math.min(1, r*1.3)*0.85})`;
          ctx.lineWidth = Math.max(0.5, r * 2);
          ctx.lineCap = 'round';
          ctx.beginPath(); ctx.moveTo(psx, psy); ctx.lineTo(sx, sy); ctx.stroke();
        }

        // ── Shooting stars ──
        shootTimer -= dt;
        if (shootTimer <= 0) {
          shooters.push(spawnShooter());
          shootTimer = 2.5 + Math.random() * 4;
        }
        for (let i = shooters.length - 1; i >= 0; i--) {
          const s = shooters[i];
          s.x += s.vx * dt;
          s.y += s.vy * dt;
          s.life -= s.decay * dt;
          if (s.life <= 0) { shooters.splice(i, 1); continue; }
          const mag = Math.sqrt(s.vx * s.vx + s.vy * s.vy);
          const tailX = s.x - (s.vx / mag) * s.len;
          const tailY = s.y - (s.vy / mag) * s.len;
          const sg = ctx.createLinearGradient(s.x, s.y, tailX, tailY);
          sg.addColorStop(0, `rgba(255,255,255,${s.life * 0.9})`);
          sg.addColorStop(0.3, `rgba(200,220,255,${s.life * 0.4})`);
          sg.addColorStop(1, 'rgba(150,180,255,0)');
          ctx.strokeStyle = sg;
          ctx.lineWidth = 1.5;
          ctx.lineCap = 'round';
          ctx.beginPath(); ctx.moveTo(s.x, s.y); ctx.lineTo(tailX, tailY); ctx.stroke();
          // Head glow
          ctx.fillStyle = `rgba(255,255,255,${s.life * 0.6})`;
          ctx.beginPath(); ctx.arc(s.x, s.y, 1.5, 0, Math.PI*2); ctx.fill();
        }

        animId = requestAnimationFrame(animate);
      }

      init();
      lastTime = performance.now();
      animId = requestAnimationFrame(animate);

      window.addEventListener('resize', () => {
        init();
        shooters = [];
      });

      // ── Daily quote overlay ──
      const quoteEl = document.createElement('div');
      quoteEl.style.cssText = 'position:fixed;bottom:18%;left:0;right:0;text-align:center;z-index:1;pointer-events:none;opacity:0;transition:opacity 1.5s ease;';
      quoteEl.innerHTML = '<p id="quote-2d" style="display:inline-block;max-width:70vw;padding:0 1em;font-size:clamp(14px,2.5vw,20px);color:rgba(220,215,205,0.75);font-family:serif;letter-spacing:0.08em;line-height:1.8;"></p>';
      c.parentElement.insertBefore(quoteEl, c.nextSibling);

      const langParam = location.pathname.startsWith('/en') ? 'en' : 'zh';
      fetch('/quotes.json').then(r => r.json()).then(data => {
        const list = data[langParam] || data['zh'] || [];
        if (!list.length) return;
        // Pick today's quote (deterministic by date)
        const dayIndex = (new Date().getFullYear() * 366 + new Date().getMonth() * 31 + new Date().getDate()) % list.length;
        const p = document.getElementById('quote-2d');
        if (p) p.textContent = list[dayIndex];
        quoteEl.style.opacity = '1';
      }).catch(() => {});

      // Fade out when 3D is ready
      window._fade2d = function() {
        if (animId) cancelAnimationFrame(animId);
        c.style.transition = 'opacity 1.5s ease';
        c.style.opacity = '0';
        quoteEl.style.opacity = '0';
        setTimeout(() => { c.style.display = 'none'; quoteEl.remove(); }, 1600);
      };
    })();

    // ── 光年进度模拟:立即启动,不等 3D ──
    const TRAVEL_BASE = 888;            // 光年基数(与 frontmatter 的 TRAVEL_BASE 保持一致)
    const lyEl = document.getElementById('travel-ly');
    const travelOverlay = document.querySelector('.travel-overlay');
    let arrived = false;
    const startT = performance.now();
    const DURATION = 4000;              // 4 秒 ease-out 到 ~95%,然后等 iframe load 兜底
    function tickTravel(now) {
      if (arrived) return;
      const t = Math.min(1, (now - startT) / DURATION);
      const p = 0.95 * (1 - Math.pow(1 - t, 3));   // ease-out cubic,封顶 0.95
      if (lyEl) lyEl.textContent = Math.max(1, Math.round(TRAVEL_BASE * (1 - p)));
      if (t < 1) requestAnimationFrame(tickTravel); // 到 0.95 后停下,等抵达
    }
    requestAnimationFrame(tickTravel);

    // ── Loading sequence: 2D 立即(星空+干支+光年+hero) → 3D (idle) → 最新文章淡入 ──
    const bg3d = document.getElementById('bg-3d');
    const stage3d = document.getElementById('stage-3d');
    if (bg3d) {
      function load3d() {
        bg3d.src = '/3d-background.html?v=202606131954';
        bg3d.addEventListener('load', () => {
          bg3d.style.opacity = '1';
          // 抵达 07 星球:光年归 0,2D 加载元素(星空/每日一句/光年文字/hero 按钮)淡出
          arrived = true;
          if (lyEl) lyEl.textContent = '0';
          if (travelOverlay) travelOverlay.style.opacity = '0';
          if (window._fade2d) setTimeout(window._fade2d, 500);
          // 最新文章淡入
          if (stage3d) setTimeout(() => { stage3d.style.opacity = '1'; }, 1200);
        });
      }
      // Start loading 3D as soon as browser is idle
      if ('requestIdleCallback' in window) {
        requestIdleCallback(load3d);
      } else {
        window.addEventListener('load', load3d);
      }
    }
  </script>

  <!-- ── stage-2d:立即显示,常驻 ── 中心「星际航行」进度文字 + hero 按钮(干支留到 3D 阶段) -->
  <div id="stage-2d" class="relative" style="z-index: 1;">
    <!-- 中心 overlay:光年进度 + hero 按钮(3D 抵达后整体淡出) -->
    <div class="travel-overlay" style="position:fixed; top:34%; left:0; right:0; text-align:center; z-index:1; pointer-events:none; opacity:1; transition:opacity 1s ease;">
      <p style="margin:0; font-family:serif; letter-spacing:0.12em; font-size:clamp(15px,2.6vw,22px); color:rgba(220,225,230,0.82); text-shadow:0 1px 8px rgba(0,0,0,0.5);">
        {lang === 'zh' ? '距离 07 星球还有 ' : 'Light-years to Planet 07: '}<span id="travel-ly" style="font-family:ui-monospace,monospace; color:rgba(255,240,200,0.95);">{TRAVEL_BASE}</span>{lang === 'zh' ? ' 光年' : ''}
      </p>
      <a
        href={`/${lang}/about/`}
        class="hero-btn"
        style="display:inline-block; margin-top:1.5rem; padding:0.6rem 1.7rem; font-size:clamp(14px,2vw,16px); letter-spacing:0.08em; pointer-events:auto; text-decoration:none;"
      >
        {lang === 'zh' ? '关于我 →' : 'About me →'}
      </a>
    </div>
  </div>

  <!-- ── stage-3d:等 3D 加载完成后淡入 ── 干支(打字机) + 最新文章 -->
  <div id="stage-3d" class="relative pointer-events-none" style="z-index: 1; opacity: 0; transition: opacity 2s ease;">
    <!-- SunArc 完整保留(2D 天空/太阳/星星/月亮 + 干支打字机),整体在 3D 之后淡入 -->
    <SunArc client:idle lang={lang} />

    <!-- Spacer — enough room for daily quote on mobile -->
    <div class="h-64 md:h-72"></div>

    <!-- Recent Post -->
    {latestPost && (
      <section class="pt-12 md:pt-12 pb-20 md:pb-32 max-w-2xl mx-auto px-4 pointer-events-auto">
        <div class="flex items-center justify-between mb-6 md:mb-8">
          <h2 class="text-lg md:text-xl font-bold" style="color: rgba(220,225,230,0.9);">
            {lang === 'zh' ? '最新文章' : 'Recent Post'}
          </h2>
          <a href={`/${lang}/blog/`} class="text-sm transition-colors" style="color: rgba(200,208,216,0.7);">
            {lang === 'zh' ? '所有文章 →' : 'All posts →'}
          </a>
        </div>
        <a
          href={`/${lang}/blog/${latestPost.id.split('/').slice(1).join('/')}/`}
          class="block group"
        >
          <div class="flex items-baseline gap-3 md:gap-4">
            <time class="shrink-0 text-xs md:text-sm font-mono" style="color: rgba(180,190,200,0.6);">
              {latestPost.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                year: 'numeric', month: 'short', day: 'numeric'
              })}
            </time>
            <h3 class="text-base md:text-lg font-semibold group-hover:text-accent transition-colors" style="color: rgba(220,225,230,0.9);">
              {latestPost.data.title}
            </h3>
          </div>
          {latestPost.data.description && (
            <p class="text-sm mt-2 ml-0 md:ml-[calc(8rem+1rem)]" style="color: rgba(180,190,200,0.5);">
              {latestPost.data.description}
            </p>
          )}
        </a>
      </section>
    )}
  </div>
</PageLayout>
