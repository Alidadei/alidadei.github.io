---
import PageLayout from '../../../layouts/PageLayout.astro';
import { type Lang } from '../../../data/site';
import { getUI } from '../../../i18n/ui';
import { getCollection } from 'astro:content';
import { categoryTree, getDefaultCategories, getCategoryLabel } from '../../../data/categories';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = getUI.bind(null, lang as Lang);

const allPosts = await getCollection('posts', ({ data }) => data.lang === lang && !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

// Enrich posts with categories
const enrichPosts = posts.map((p) => {
  const cats = p.data.categories || (p.data.category ? [p.data.category] : getDefaultCategories());
  return { ...p, _categories: cats };
});

const topCategories = categoryTree;
---

<PageLayout title={t('nav.blog')}>
  <h1 class="text-3xl font-bold text-primary mb-6">{t('nav.blog')}</h1>

  <!-- Category Tabs -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button
      data-category="all"
      class="category-tab px-4 py-2 text-sm rounded-full bg-accent text-white transition-colors cursor-pointer"
    >
      {t('blog.category.all')}
    </button>
    {topCategories.map((cat) => (
      <button
        data-category={cat.slug}
        class="category-tab px-4 py-2 text-sm rounded-full bg-bg-tertiary text-text-secondary hover:bg-accent/10 hover:text-accent transition-colors cursor-pointer"
      >
        {cat.label[lang]}
      </button>
    ))}
  </div>

  <!-- Search -->
  <div class="mb-6">
    <input
      id="blog-search"
      type="text"
      placeholder={lang === 'zh' ? '搜索文章...' : 'Search posts...'}
      class="w-full px-4 py-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-colors"
    />
    <p id="search-count" class="text-sm text-[var(--color-text-muted)] mt-2 hidden"></p>
  </div>

  {allTags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      {allTags.map((tag) => (
        <span class="px-3 py-1 text-sm rounded-full bg-bg-tertiary text-text-secondary hover:bg-accent/10 hover:text-accent cursor-pointer transition-colors">
          {tag}
        </span>
      ))}
    </div>
  )}

  {enrichPosts.length === 0 ? (
    <p class="text-text-muted">{lang === 'zh' ? '暂无文章' : 'No posts yet.'}</p>
  ) : (
    <div class="space-y-6" id="posts-list">
      {enrichPosts.map((post) => {
        const slug = post.id.split('/').slice(1).join('/');
        return (
          <a
            href={`/${lang}/blog/${slug}/`}
            data-categories={JSON.stringify(post._categories)}
            class="post-card block p-6 rounded-lg border border-border hover:border-accent/50 hover:shadow-sm transition-all group"
          >
            <div class="flex items-center gap-2 mb-2">
              {post._categories.length > 0 && (
                <span class="px-2 py-0.5 text-xs rounded bg-accent/10 text-accent">
                  {getCategoryLabel(post._categories, lang)}
                </span>
              )}
            </div>
            <h2 class="text-xl font-semibold text-primary group-hover:text-accent transition-colors mb-2">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-text-muted text-sm mb-3">{post.data.description}</p>
            )}
            <div class="flex items-center justify-between">
              <time class="text-xs text-text-muted">
                {post.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </time>
              {post.data.tags.length > 0 && (
                <div class="flex gap-1">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="px-2 py-0.5 text-xs rounded bg-bg-tertiary text-text-muted">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  )}

  <p id="no-results" class="text-text-muted hidden">{lang === 'zh' ? '该分类暂无文章' : 'No posts in this category'}</p>
</PageLayout>

<script>
  function initBlogPage() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.category-tab');
    const cards = document.querySelectorAll<HTMLElement>('.post-card');
    const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
    const searchCount = document.getElementById('search-count');
    const noResults = document.getElementById('no-results');
    const postsList = document.getElementById('posts-list');
    let activeCategory = 'all';

    // Tab switching
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        activeCategory = tab.dataset.category || 'all';
        tabs.forEach(t => {
          t.classList.remove('bg-accent', 'text-white');
          t.classList.add('bg-bg-tertiary', 'text-text-secondary');
        });
        tab.classList.remove('bg-bg-tertiary', 'text-text-secondary');
        tab.classList.add('bg-accent', 'text-white');
        filterPosts();
      });
    });

    // Search
    searchInput?.addEventListener('input', () => filterPosts());

    function filterPosts() {
      const query = (searchInput?.value || '').toLowerCase().trim();
      let visible = 0;

      cards.forEach(card => {
        const cats: string[] = JSON.parse(card.dataset.categories || '[]');
        const categoryMatch = activeCategory === 'all' || cats.includes(activeCategory);

        const title = card.querySelector('h2')?.textContent?.toLowerCase() || '';
        const desc = card.querySelector('.text-text-muted')?.textContent?.toLowerCase() || '';
        const tags = Array.from(card.querySelectorAll('.text-xs.bg-bg-tertiary')).map(t => t.textContent?.toLowerCase() || '');
        const textMatch = !query || title.includes(query) || desc.includes(query) || tags.some(t => t.includes(query));

        if (categoryMatch && textMatch) {
          card.classList.remove('hidden');
          visible++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (postsList) postsList.classList.toggle('hidden', visible === 0);
      if (noResults) noResults.classList.toggle('hidden', visible > 0);

      if (searchCount && query) {
        const isZh = document.documentElement.lang?.startsWith('zh');
        searchCount.textContent = visible > 0
          ? `${visible} ${isZh ? '条结果' : 'results'}`
          : (isZh ? '没有找到匹配的文章' : 'No matching posts found');
        searchCount.classList.remove('hidden');
      } else if (searchCount) {
        searchCount.classList.add('hidden');
      }
    }
  }

  initBlogPage();
</script>
