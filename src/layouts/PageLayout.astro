---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  fullWidth?: boolean;
  noindex?: boolean;
}

const { title, description, image, fullWidth = false, noindex = false } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} noindex={noindex}>
  <Header />
  <main class={fullWidth ? '' : 'max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 fade-in'}>
    <slot />
  </main>
  <Footer />
</BaseLayout>
