---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { type Lang } from '../data/site';
import { getCategoryLabel } from '../data/categories';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  image?: string;
  categories?: string[];
  lang?: Lang;
}

const { title, description, date, tags = [], image, categories = [], lang = 'zh' } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <!-- KaTeX CSS only loaded on blog post pages -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  <article class="max-w-6xl mx-auto xl:translate-x-12 px-4 sm:px-6 lg:px-8 py-8 fade-in">
    <header class="mb-4">
      <!-- Category breadcrumb -->
      {categories.length > 0 && (
        <nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm text-text-muted mb-4 flex-wrap">
          <a href={`/${lang}/blog/`} class="hover:text-accent transition-colors">{lang === 'zh' ? '博客' : 'Blog'}</a>
          <span class="text-text-muted">›</span>
          {categories.map((cat, i) => {
            const path = categories.slice(0, i + 1);
            const label = getCategoryLabel(path, lang).split(' > ').pop();
            const isLast = i === categories.length - 1;
            return (
              <Fragment>
                {i > 0 && <span class="text-text-muted">›</span>}
                {isLast ? (
                  <span class="text-primary font-medium" aria-current="page">{label}</span>
                ) : (
                  <a href={`/${lang}/blog/category/${path.join('/')}/`} class="hover:text-accent transition-colors">{label}</a>
                )}
              </Fragment>
            );
          })}
        </nav>
      )}
      <h1 class="text-3xl sm:text-4xl font-bold text-primary mb-4 leading-tight">{title}</h1>
      <div class="article-title-line"></div>
      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4 text-sm text-text-muted">
        {date && (
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        )}
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="tag-chip">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Article body with TOC sidebar -->

    <!-- Mobile floating TOC button (visible below lg) -->
    <button
      id="toc-mobile-btn"
      class="lg:hidden fixed right-3 top-1/2 -translate-y-1/2 z-40 w-10 h-10 rounded-full bg-bg-secondary/90 backdrop-blur border border-border shadow-md flex items-center justify-center text-text-muted hover:text-accent hover:border-accent transition-all"
      aria-label={lang === 'zh' ? '目录' : 'Table of Contents'}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/>
      </svg>
    </button>

    <!-- Mobile TOC slide-out panel -->
    <div id="toc-mobile-panel" class="lg:hidden fixed inset-y-0 right-0 z-50 w-72 max-w-[80vw] translate-x-full transition-transform duration-300 ease-in-out">
      <div class="h-full bg-bg/95 backdrop-blur-md shadow-2xl border-l border-border flex flex-col">
        <!-- Panel header -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-border">
          <span class="text-sm font-semibold text-primary">{lang === 'zh' ? '目录' : 'Contents'}</span>
          <button id="toc-mobile-close" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-bg-tertiary text-text-muted hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <!-- Panel body: TOC links -->
        <nav id="toc-nav-mobile" class="flex-1 overflow-y-auto px-4 py-3 space-y-1">
          <!-- TOC items injected by JS -->
        </nav>
      </div>
    </div>
    <!-- Mobile TOC backdrop -->
    <div id="toc-mobile-backdrop" class="lg:hidden fixed inset-0 z-45 bg-black/20 opacity-0 pointer-events-none transition-opacity duration-300"></div>

    <div class="flex gap-8 relative">
      <!-- Main content -->
      <div class="flex-1 min-w-0 prose prose-lg max-w-none prose-headings:text-primary prose-a:text-accent">
        <slot />
      </div>

      <!-- Right-side TOC -->
      <aside id="toc-sidebar" class="hidden lg:block w-56 shrink-0 ml-auto">
        <div id="toc-container" class="sticky top-8">
          <h3 class="text-sm font-semibold text-primary mb-3 uppercase tracking-wide">
            {lang === 'zh' ? '目录' : 'Table of Contents'}
          </h3>
          <div id="toc-track" class="relative">
            <span id="toc-active-indicator" aria-hidden="true">
              <span id="toc-active-head"></span>
            </span>
            <nav id="toc-nav" class="space-y-1 text-sm border-l-2 border-border pl-3 max-h-[70vh] overflow-y-auto">
              <!-- TOC items injected by JS -->
            </nav>
          </div>
        </div>
      </aside>
    </div>
  </article>
  <Footer />

  <!-- TOC generation script -->
  <script>
    function initTOC() {
      const prose = document.querySelector('.prose');
      const tocNav = document.getElementById('toc-nav');
      const tocSidebar = document.getElementById('toc-sidebar');
      const tocTrack = document.getElementById('toc-track');
      if (!prose || !tocNav || !tocSidebar || !tocTrack) return;

      // Find all headings h2-h4 in prose
      const headings = prose.querySelectorAll('h2, h3, h4');
      if (headings.length === 0) {
        tocSidebar.style.display = 'none';
        return;
      }

      // Clear only generated links (for Astro page transitions). Keep the
      // continuous active-line indicator mounted in the track wrapper.
      tocNav.querySelectorAll('.toc-link').forEach((link) => link.remove());
      let tocIndicator = document.getElementById('toc-active-indicator');
      if (!tocIndicator) {
        tocIndicator = document.createElement('span');
        tocIndicator.id = 'toc-active-indicator';
        tocIndicator.setAttribute('aria-hidden', 'true');
        tocTrack.prepend(tocIndicator);
      }
      let tocActiveHead = document.getElementById('toc-active-head');
      if (!tocActiveHead) {
        tocActiveHead = document.createElement('span');
        tocActiveHead.id = 'toc-active-head';
        tocIndicator.appendChild(tocActiveHead);
      }

      // Also prepare mobile TOC
      const tocNavMobile = document.getElementById('toc-nav-mobile');
      if (tocNavMobile) tocNavMobile.innerHTML = '';

      // Compute the fixed header height for accurate scroll offset
      const header = document.querySelector('header') || document.querySelector('nav');
      const headerHeight = header ? header.getBoundingClientRect().height : 0;
      // Extra padding so heading sits comfortably below the header
      const scrollOffset = headerHeight + 24;

      headings.forEach((heading, index) => {
        // Generate an id if missing
        if (!heading.id) {
          heading.id = 'toc-h-' + index + '-' + heading.textContent?.trim().replace(/\s+/g, '-').slice(0, 30);
        }

        const level = parseInt(heading.tagName[1]); // 2, 3, or 4
        const link = document.createElement('a');
        link.href = '#' + heading.id;
        link.textContent = heading.textContent?.trim() || '';

        // Hierarchy: section headings are stronger; subheadings are indented and lighter.
        let cls = 'toc-link block py-1 text-text-muted hover:text-accent transition-colors truncate';
        link.dataset.level = String(level);
        if (level === 2) {
          cls += ' font-semibold text-[0.85rem]';
        } else if (level === 3) {
          cls += ' pl-3 text-[0.8rem]';
        } else if (level === 4) {
          cls += ' pl-6 text-[0.75rem] opacity-80';
        }
        link.className = cls;

        tocNav.appendChild(link);

        // Also populate mobile TOC
        if (tocNavMobile) {
          const mobileLink = link.cloneNode(true) as HTMLAnchorElement;
          tocNavMobile.appendChild(mobileLink);
        }
      });

      // Hide mobile TOC button if no headings
      if (headings.length === 0) {
        const tocBtn = document.getElementById('toc-mobile-btn');
        if (tocBtn) tocBtn.style.display = 'none';
      }

      // Mobile TOC panel: open / close
      const tocPanel = document.getElementById('toc-mobile-panel');
      const tocBtn = document.getElementById('toc-mobile-btn');
      const tocClose = document.getElementById('toc-mobile-close');
      const tocBackdrop = document.getElementById('toc-mobile-backdrop');

      function openMobileTOC() {
        if (tocPanel) tocPanel.classList.remove('translate-x-full');
        if (tocBackdrop) { tocBackdrop.classList.remove('opacity-0', 'pointer-events-none'); tocBackdrop.classList.add('opacity-100'); }
      }
      function closeMobileTOC() {
        if (tocPanel) tocPanel.classList.add('translate-x-full');
        if (tocBackdrop) { tocBackdrop.classList.add('opacity-0', 'pointer-events-none'); tocBackdrop.classList.remove('opacity-100'); }
      }

      tocBtn?.addEventListener('click', openMobileTOC);
      tocClose?.addEventListener('click', closeMobileTOC);
      tocBackdrop?.addEventListener('click', closeMobileTOC);

      // Mobile TOC click: smooth scroll + close panel
      if (tocNavMobile) {
        tocNavMobile.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = (link as HTMLAnchorElement).getAttribute('href')?.slice(1);
            const target = document.getElementById(targetId || '');
            if (target) {
              const top = target.getBoundingClientRect().top + window.scrollY - scrollOffset;
              window.scrollTo({ top, behavior: 'smooth' });
              closeMobileTOC();
            }
          });
        });
      }

      // Scroll spy: highlight current heading
      const tocLinks = Array.from(tocNav.querySelectorAll('.toc-link'));
      const mobileLinks = tocNavMobile ? Array.from(tocNavMobile.querySelectorAll('.toc-link')) : [];
      const headingElements = Array.from(headings);
      const observedHeadingIndices = new Set<number>();
      const hasIntersectionObserver = 'IntersectionObserver' in window;
      let tocObserver: IntersectionObserver | null = null;
      let activeIndex = -1;

      function isAtArticleEnd() {
        const articleBottom = prose.getBoundingClientRect().bottom;
        return articleBottom <= window.innerHeight + scrollOffset;
      }

      // Fallback for browsers without IntersectionObserver and for the small
      // gaps between two headings where neither heading intersects the band.
      function getPositionFallback() {
        if (isAtArticleEnd()) return headingElements.length - 1;
        let currentIndex = 0;
        for (let i = headingElements.length - 1; i >= 0; i--) {
          const rect = headingElements[i].getBoundingClientRect();
          if (rect.top <= scrollOffset + 10) {
            currentIndex = i;
            break;
          }
        }
        return currentIndex;
      }

      function getObserverIndex() {
        if (observedHeadingIndices.size === 0) return getPositionFallback();
        const activationLine = scrollOffset + 10;
        const candidates = Array.from(observedHeadingIndices);
        // Use the heading closest to the activation line rather than the
        // callback order. This keeps upward and downward scrolling symmetrical
        // when two headings overlap the observer band.
        return candidates.reduce((closest, index) => {
          const currentDistance = Math.abs(headingElements[index].getBoundingClientRect().top - activationLine);
          const closestDistance = Math.abs(headingElements[closest].getBoundingClientRect().top - activationLine);
          return currentDistance < closestDistance ? index : closest;
        }, candidates[0]);
      }

      function updateIndicatorPosition(activeLink = tocLinks[activeIndex] as HTMLElement | undefined) {
        if (!tocIndicator || !activeLink) return;
        const trackRect = tocTrack.getBoundingClientRect();
        const linkRect = activeLink.getBoundingClientRect();
        const end = Math.min(
          Math.max(linkRect.bottom - trackRect.top, 0),
          tocTrack.clientHeight
        );
        // The line grows from the top of the track to the active item instead
        // of replacing the track with a short active border.
        tocIndicator.style.height = `${end}px`;
      }

      function setActiveHeading(currentIndex: number, force = false) {
        // Only update the DOM when the active heading changes. This keeps the
        // scroll spy responsive while allowing the active item to follow the
        // reader inside a long, scrollable TOC.
        if (currentIndex === activeIndex && !force) return;
        activeIndex = currentIndex;

        const setActiveState = (links: Element[]) => {
          links.forEach((link, index) => {
            const isActive = index === currentIndex;
            link.classList.toggle('is-active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'location');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        setActiveState(tocLinks);
        setActiveState(mobileLinks);

        // Grow one continuous indicator along the existing straight track.
        // The track remains the original border color; the accent line covers
        // the chapters already passed and ends at the current item.
        const activeLink = tocLinks[currentIndex] as HTMLElement | undefined;
        updateIndicatorPosition(activeLink);

        // Keep the active desktop item visible without changing the existing
        // straight border shape or page scroll position.
        activeLink?.scrollIntoView({
          block: 'nearest',
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth'
        });
      }

      function updateActiveHeading(force = false) {
        const currentIndex = isAtArticleEnd()
          ? headingElements.length - 1
          : (hasIntersectionObserver && observedHeadingIndices.size > 0
            ? getObserverIndex()
            : getPositionFallback());
        setActiveHeading(currentIndex, force);
      }

      // Fumadocs-style anchor tracking: headings become active while they
      // intersect a narrow band below the fixed header. The scroll listener
      // below remains as a fallback for the gaps and the article end.
      if (hasIntersectionObserver) {
        tocObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const index = headingElements.indexOf(entry.target);
            if (index < 0) return;
            if (entry.isIntersecting) {
              observedHeadingIndices.add(index);
            } else {
              observedHeadingIndices.delete(index);
            }
          });
          updateActiveHeading();
        }, {
          rootMargin: `-${scrollOffset}px 0px -70% 0px`,
          threshold: 0
        });
        headingElements.forEach((heading) => tocObserver?.observe(heading));
      }

      // Smooth scroll on click — use getBoundingClientRect for accurate position
      tocLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = (link as HTMLAnchorElement).getAttribute('href')?.slice(1);
          const target = document.getElementById(targetId || '');
          if (target) {
            const top = target.getBoundingClientRect().top + window.scrollY - scrollOffset;
            window.scrollTo({
              top: top,
              behavior: 'smooth'
            });
          }
        });
      });

      // Throttled scroll listener
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateActiveHeading();
            ticking = false;
          });
          ticking = true;
        }
      });
      window.addEventListener('resize', () => updateActiveHeading(true));
      tocNav.addEventListener('scroll', () => {
        if (activeIndex < 0) return;
        updateIndicatorPosition();
      });

      // Initial state
      updateActiveHeading();
    }

    // Run on page load and after Astro page transitions
    document.addEventListener('astro:page-load', initTOC);
    initTOC();
  </script>
</BaseLayout>
