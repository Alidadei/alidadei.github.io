---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { type Lang } from '../data/site';
import { getCategoryLabel } from '../data/categories';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  image?: string;
  categories?: string[];
  lang?: Lang;
}

const { title, description, date, tags = [], image, categories = [], lang = 'zh' } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 fade-in">
    <header class="mb-8">
      <!-- Category breadcrumb -->
      {categories.length > 0 && (
        <nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm text-text-muted mb-3 flex-wrap">
          <a href={`/${lang}/blog/`} class="hover:text-accent transition-colors">{lang === 'zh' ? '博客' : 'Blog'}</a>
          <span class="text-text-muted">›</span>
          {categories.map((cat, i) => {
            const path = categories.slice(0, i + 1);
            const label = getCategoryLabel(path, lang).split(' > ').pop();
            const isLast = i === categories.length - 1;
            return (
              <Fragment>
                {i > 0 && <span class="text-text-muted">›</span>}
                {isLast ? (
                  <span class="text-primary font-medium" aria-current="page">{label}</span>
                ) : (
                  <a href={`/${lang}/blog/category/${path.join('/')}/`} class="hover:text-accent transition-colors">{label}</a>
                )}
              </Fragment>
            );
          })}
        </nav>
      )}
      <h1 class="text-3xl font-bold text-primary mb-4">{title}</h1>
      {date && (
        <time datetime={date.toISOString()} class="text-text-muted text-sm">
          {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      {tags.length > 0 && (
        <div class="flex gap-2 mt-3">
          {tags.map((tag) => (
            <span class="px-2 py-1 text-xs rounded bg-bg-tertiary text-text-secondary">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-accent">
      <slot />
    </div>
  </article>
  <Footer />
</BaseLayout>
