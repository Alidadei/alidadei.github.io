---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { type Lang } from '../data/site';
import { getCategoryLabel } from '../data/categories';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  image?: string;
  categories?: string[];
  lang?: Lang;
}

const { title, description, date, tags = [], image, categories = [], lang = 'zh' } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 fade-in">
    <header class="mb-10">
      <!-- Category breadcrumb -->
      {categories.length > 0 && (
        <nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm text-text-muted mb-4 flex-wrap">
          <a href={`/${lang}/blog/`} class="hover:text-accent transition-colors">{lang === 'zh' ? '博客' : 'Blog'}</a>
          <span class="text-text-muted">›</span>
          {categories.map((cat, i) => {
            const path = categories.slice(0, i + 1);
            const label = getCategoryLabel(path, lang).split(' > ').pop();
            const isLast = i === categories.length - 1;
            return (
              <Fragment>
                {i > 0 && <span class="text-text-muted">›</span>}
                {isLast ? (
                  <span class="text-primary font-medium" aria-current="page">{label}</span>
                ) : (
                  <a href={`/${lang}/blog/category/${path.join('/')}/`} class="hover:text-accent transition-colors">{label}</a>
                )}
              </Fragment>
            );
          })}
        </nav>
      )}
      <h1 class="text-3xl sm:text-4xl font-bold text-primary mb-4 leading-tight">{title}</h1>
      <div class="article-title-line"></div>
      <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted">
        {date && (
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        )}
        {tags.length > 0 && (
          <div class="flex gap-1.5">
            {tags.map((tag) => (
              <span class="tag-chip">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>
    <div class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-accent">
      <slot />
    </div>
  </article>
  <Footer />
</BaseLayout>
