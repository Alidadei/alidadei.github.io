{
  "name": "yhl-github-io-v2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "esbuild src/3d/background.ts --bundle --format=esm --outfile=public/three-bg.js && node scripts/sync-quotes.mjs && node scripts/run-astro.mjs dev",
    "sky-preview": "node scripts/sky-preview.mjs",
    "build": "esbuild src/3d/background.ts --bundle --format=esm --minify --outfile=public/three-bg.js && node scripts/sync-quotes.mjs && npm run thumbs && astro build && node tests/check-rendered-markdown.mjs && node scripts/bump-sw-version.mjs",
    "build:3d": "esbuild src/3d/background.ts --bundle --format=esm --minify --outfile=public/three-bg.js",
    "thumbs": "node scripts/gen-portfolio-thumbs.mjs",
    "cms": "node scripts/cms.mjs",
    "new-post": "node scripts/new-post.mjs",
    "favicon": "node scripts/set-favicon.mjs",
    "avatar": "node scripts/set-avatar.mjs",
    "compress-posts": "node scripts/compress-post-images.mjs",
    "check:markdown": "node --test tests/post-heading-levels.test.mjs tests/remark-cjk-friendly-strong.test.mjs tests/shiki-text-diagram.test.mjs && node tests/check-rendered-markdown.mjs",
    "check:mobile-overflow": "node tests/mobile-overflow-regression.mjs",
    "check:worker-security": "node --experimental-strip-types --test tests/worker-cors.test.mjs",
    "preview": "node scripts/run-astro.mjs preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.3",
    "lunar-javascript": "^1.7.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@inquirer/prompts": "^8.5.2",
    "esbuild": "^0.28.1",
    "sharp": "^0.35.1"
  }
}
